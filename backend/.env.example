# FlashPulse AI Environment Variables
# Copy this file to .env in the same directory and fill in your credentials.

# The LLM API provider to use: 'openai' or 'anthropic' (default: openai)
LLM_PROVIDER=openai

# OpenAI API Key (Required if LLM_PROVIDER is 'openai')
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Required if LLM_PROVIDER is 'anthropic')
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Model overrides (Optional)
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Server configuration
PORT=8000
HOST=0.0.0.0
