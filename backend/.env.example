# FlashPulse AI Environment Variables
# Copy this file to .env in the backend/ directory and fill in your credentials.
# NEVER commit the .env file to version control.
#
# For AWS deployment, set these as environment variables in your App Runner / EBS environment.

# --- LLM Provider Configuration ---

# The LLM API provider: 'openai', 'anthropic', or 'gemini' (default: openai)
LLM_PROVIDER=openai

# OpenAI API Key (Required if LLM_PROVIDER is 'openai')
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Required if LLM_PROVIDER is 'anthropic')
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini API Key (Required if LLM_PROVIDER is 'gemini')
GEMINI_API_KEY=your_gemini_api_key_here

# --- LLM Model Overrides (Optional) ---
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Server Configuration ---
PORT=8000
HOST=0.0.0.0

# --- CORS / Security (Optional, defaults to open in development) ---
# Set to your frontend domain in production, e.g. https://your-app.awsapprunner.com
# Comma-separated list for multiple origins
# CORS_ORIGINS=https://your-app.awsapprunner.com
